{
  "productName": "Zyl OS Emulator",
  "version": "0.1.0",
  "identifier": "com.zylos.emulator",
  "build": {
    "frontendDist": "./ui",
    "beforeDevCommand": "bash scripts/deploy-apps.sh"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Zyl OS Emulator",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob: mediastream:; frame-src 'self' https: http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "resources": []
  }
}