[Unit]
Description=Zyl OS AppArmor Profile Loader
DefaultDependencies=no
Before=zyl-wam.service zyl-compositor.service
After=apparmor.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/sh -c 'for p in /etc/apparmor.d/zyl-*; do apparmor_parser -r "$p" 2>/dev/null || true; done'

[Install]
WantedBy=zyl-os.target
