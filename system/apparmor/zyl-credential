# ----------------------------------------------------------
# [Clean Architecture] Infrastructure Layer - Security Policy
#
# 역할: Credential Manager 서비스 AppArmor 프로파일
# 수행범위: 암호화된 자격증명 저장소 파일 접근. 네트워크/디바이스 접근 최소화.
# 의존방향: /usr/bin/zyl-credential 바이너리에 적용
# SOLID: SRP — Credential 서비스 격리 정책만 담당
# ----------------------------------------------------------

#include <tunables/global>

profile zyl-credential /usr/bin/zyl-credential {
  #include <abstractions/base>
  #include <abstractions/dbus-session>

  # Credential service binary
  /usr/bin/zyl-credential                 mr,

  # Libraries
  /usr/lib/zyl-os/**                      mr,
  /usr/lib/@{multiarch}/**                mr,

  # Encrypted credential store (owner-only)
  owner /var/lib/zyl-os/credential/**     rw,
  owner /data/users/*/credentials/**      rw,

  # Random number source for key generation
  /dev/urandom                            r,
  /dev/random                             r,

  # Shared OS resources (read-only)
  /usr/share/zyl-os/**                    r,

  # Zyl OS D-Bus session bus (accept calls from WAM apps)
  dbus (send, receive) bus=session
       peer=(name=org.zylos.*),

  # /proc/self for PBKDF2 salt source (getpid)
  /proc/@{pid}/status                     r,

  # Deny all network access — credentials must not leave the device
  deny network inet stream,
  deny network inet dgram,
  deny network inet6 stream,
  deny network inet6 dgram,

  # Deny sensitive system paths
  deny /dev/mem                           rwmlkx,
  deny /dev/kmem                          rwmlkx,
  deny /proc/kcore                        rwmlkx,
  deny /dev/input/**                      rwmlkx,
  deny /dev/dri/**                        rwmlkx,
  deny /usr/**                            w,
  deny /etc/**                            w,
  deny /boot/**                           rwmlkx,

  # Deny ptrace — prevent credential extraction via debug
  deny ptrace,
}
